# Copy to .env.local for local dev (server reads via process.env).
# For local-only running without GCP, leave GCP_* unset and Gemini calls will fail —
# the archetype catalog still loads from data/archetypes.seed.json so the UI works.

GCP_PROJECT=
GCP_LOCATION=us-central1
GCS_BUCKET=
GEMINI_MODEL=gemini-2.5-pro
PORT=8080
