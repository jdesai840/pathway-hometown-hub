# Files NOT uploaded to Cloud Build when running `gcloud run deploy --source .`

.git/
.gitignore
.gcloudignore

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Dependencies — Cloud Build runs npm ci from package*.json
node_modules/
*/node_modules/

# Build outputs (we build inside the Dockerfile)
web/dist/
server/dist/

# Pipeline-only data containing athlete names (NIL) — must NOT ship in the image
data/athletes.raw.json

# Plans + setup docs (not needed in the image)
GCP_SETUP.md
*.md.bak

# Local env
.env
.env.*
*.log
